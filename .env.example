# Shared Mongo settings used by the local DB scripts and optional state API.
NIRA_MONGODB_URI=mongodb://127.0.0.1:27017
NIRA_MONGODB_DB_NAME=nira_db

# Base path for subpath hosting such as GitHub Pages.
# Keep `/` for local dev, Vercel, and VM/Nginx deployments.
VITE_APP_BASE_PATH=/

# Supabase frontend credentials (required only when database sync is enabled)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# guna_emr converter-agent base URL
VITE_GUNA_EMR_BASE_URL=http://localhost:3001

# CDSS orchestrator base URL
VITE_CDSS_BASE_URL=http://localhost:8010

# Optional local API used to persist runtime app state to MongoDB.
# Static hosts like GitHub Pages and Vercel cannot run this process directly.
VITE_MONGO_STATE_API_URL=http://localhost:7071
