# Base path for subpath hosting such as GitHub Pages.
# Keep `/` for local dev, Vercel, and VM/Nginx deployments.
VITE_APP_BASE_PATH=/

# Supabase frontend credentials (required only when database sync is enabled)
VITE_SUPABASE_URL=https://ywvpgoplqooygmvtrwcb.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_j-pYeu-qQVfNKHLgWAt--Q_K6axLNqn

# Optional Supabase snapshot key used to hydrate/persist the demo store remotely.
# Leave empty to stay localStorage-only.
VITE_SUPABASE_STATE_SNAPSHOT_KEY=primary

# Supabase Postgres connection string for migration scripts
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# guna_emr converter-agent base URL
# Local dev: use the bundled converter-agent on port 3001.
# Proxy-based deployment: leave blank and let the frontend use same-origin /api routes.
VITE_GUNA_EMR_BASE_URL=http://localhost:3001

# Anthropic Claude settings for the local converter-agent server
ANTHROPIC_API_KEY=your-anthropic-api-key
LLM_MODEL=claude-haiku-4-5
LLM_BASE_URL=https://api.anthropic.com/v1
PORT=3001

# CDSS-style analysis routes are served by the same local converter-agent by default.
# Proxy-based deployment: leave blank and let the frontend use same-origin /cdss routes.
VITE_CDSS_BASE_URL=http://localhost:3001
